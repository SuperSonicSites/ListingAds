node_modules/
dist/
.astro/
.tmp/

.env
.env.*
!.env.example

# Everything under data/ is runtime state on the production volume (brokerage
# profiles with intake tokens, ad requests, uploaded photos, frozen report
# snapshots) — never committed, never touched by deploys.
data/brokerages/*.json
!data/brokerages/.gitkeep
data/requests/*.json
!data/requests/.gitkeep
data/snapshots/*.json
!data/snapshots/.gitkeep
data/uploads/*
!data/uploads/.gitkeep

*.log

.claude/
