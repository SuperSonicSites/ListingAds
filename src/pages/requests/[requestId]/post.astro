---
import AppLayout from "../../../layouts/AppLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { readBrokerage, readRequest } from "../../../lib/storage";
import { HEADLINE_FLAGS } from "../../../lib/types";
import { STATUS_LABELS } from "../../../lib/status";
import { formatDate } from "../../../lib/format";

const requestId = Astro.params.requestId ?? "";
let request;
try {
  request = await readRequest(requestId);
} catch {
  return Astro.redirect("/");
}
const brokerage = await readBrokerage(request.brokerage_slug).catch(() => undefined);
if (!brokerage) {
  return Astro.redirect(`/requests/${request.id}`);
}

const draft = request.post;
const photos = request.assets.filter((asset) => asset.kind === "post_photo");
const photoIdsOnDisk = new Set(photos.map((photo) => photo.id));
const initialSelection = draft.photo_ids.filter((id) => photoIdsOnDisk.has(id));
const shortLink = request.short_link?.url ?? "";
const published = request.post_published;

const postApi = `/api/requests/${request.id}/post`;
const publishApi = `/api/requests/${request.id}/publish-post`;
const uploadApi = `/api/requests/${request.id}/upload`;
const fetchPhotosApi = `/api/requests/${request.id}/fetch-photos`;
const uploadsBase = `/api/uploads/${request.id}`;
const hasStatsLink = Boolean(request.realtor_stats_link);

const canReady = request.status === "new_order" && request.campaign_type !== "extend";
const isExtendAtNewOrder = request.status === "new_order" && request.campaign_type === "extend";
const canPublish = request.status === "post_reviewed" && !published;

const savedFlag = Astro.url.searchParams.get("saved") === "1";
const publishedFlag = Astro.url.searchParams.get("published") === "1";
const warning = Astro.url.searchParams.get("warning") ?? "";

const publishedDate = published ? formatDate(published.published_at.slice(0, 10)) : "";
---

<AppLayout title={`Post editor — ${request.listing_address}`} className="app-body">
  <SiteHeader context="Post editor" />
  <main class="app-shell">
    <a class="back-link" href={`/requests/${request.id}`}>&larr; Back to request</a>
    <header class="page-header">
      <p class="eyebrow">Post editor &middot; {STATUS_LABELS[request.status]}</p>
      <h1>{request.listing_address}</h1>
      <p>Draft the Facebook post for {brokerage.name}. The preview mirrors the final text exactly as it will publish.</p>
    </header>

    {warning && <p class="notice amber" role="alert">{warning}</p>}
    {publishedFlag && published && <p class="notice green">The post is recorded as published. 🎉</p>}
    {savedFlag && <p class="notice green">Draft saved.</p>}
    {
      published && (
        <p class="notice green">
          Post published{published.manual && " (recorded manually)"} on {publishedDate}
          {published.permalink_url && (
            <>
              {" — "}
              <a href={published.permalink_url} target="_blank" rel="noopener">
                View on Facebook
              </a>
            </>
          )}
        </p>
      )
    }
    {
      !shortLink && (
        <p class="notice red">
          Create the nowforsale.co link on the <a href={`/requests/${request.id}`}>request page</a> first — publishing
          is disabled until it exists.
        </p>
      )
    }

    <div class="editor-grid">
      <div class="editor-left">
        <form id="post-form" method="post" action={postApi}>
          <input type="hidden" name="dirty" id="f-dirty" value={draft.dirty ? "1" : "0"} />
          <input type="hidden" name="photo_ids" id="f-photo-ids" value={initialSelection.join(",")} />

          <section class="panel editor-panel">
            <h2>Post details</h2>
            <div class="client-field-grid two">
              <label class="client-field">
                <span>Headline flag</span>
                <select name="headline_flag" id="f-flag">
                  {HEADLINE_FLAGS.map((flag) => (
                    <option value={flag} selected={flag === draft.headline_flag}>
                      {flag}
                    </option>
                  ))}
                </select>
              </label>
              <label class="client-field">
                <span>Price prefix</span>
                <select name="price_prefix" id="f-prefix">
                  <option value="Offered at" selected={draft.price_prefix !== "Now Offered at"}>Offered at</option>
                  <option value="Now Offered at" selected={draft.price_prefix === "Now Offered at"}>
                    Now Offered at
                  </option>
                </select>
              </label>
              <label class="client-field">
                <span>Price (numbers only, no $)</span>
                <input type="text" name="price" id="f-price" inputmode="numeric" placeholder="809,900" maxlength="20" value={draft.price} />
              </label>
              <label class="client-field">
                <span>Neighborhood</span>
                <input type="text" name="neighborhood" id="f-neigh" placeholder="Whistle Bend" maxlength="80" value={draft.neighborhood} />
              </label>
              <label class="client-field">
                <span>Bedrooms</span>
                <input type="number" name="beds" id="f-beds" step="0.5" min="0" value={draft.beds} />
              </label>
              <label class="client-field">
                <span>Bathrooms</span>
                <input type="number" name="baths" id="f-baths" step="0.5" min="0" value={draft.baths} />
              </label>
              <label class="client-field wide">
                <span>Body — descriptive paragraphs</span>
                <textarea name="body" id="f-body" rows="8" maxlength="2000">{draft.body}</textarea>
              </label>
            </div>

            <div class="readonly-rows">
              <div class="readonly-row">
                <strong>Short link</strong>
                <span>{shortLink || "— not created yet —"}</span>
              </div>
              <div class="readonly-row">
                <strong>📞</strong>
                <span>{brokerage.post_phone_line || "— no phone line on the brokerage profile —"}</span>
              </div>
              <div class="readonly-row">
                <strong>Sign-off</strong>
                <span>{brokerage.post_signoff || "— no sign-off on the brokerage profile —"}</span>
              </div>
            </div>
          </section>

          <section class="panel editor-panel">
            <div class="final-heading">
              <h2>Final post text</h2>
              <button class="button secondary sm" type="button" id="regen">Regenerate from fields</button>
            </div>
            <p class="hint">
              This exact text gets published. Edit it freely — manual edits are kept until you regenerate.
            </p>
            <textarea name="final_text" id="f-final" rows="14">{draft.final_text}</textarea>
          </section>

          <section class="panel editor-panel">
            <div class="final-heading">
              <h2>Photos</h2>
              <span class="count-badge" id="pick-count">{initialSelection.length} of 10 picked</span>
            </div>
            <p class="hint">
              Fetch pulls the first 10 listing photos from REALTOR.ca; drop files here to add or replace.
            </p>
            <div class="photos-toolbar">
              <button class="button secondary sm" type="button" id="fetch-photos" disabled={!hasStatsLink}>
                Fetch photos from REALTOR.ca
              </button>
              {
                !hasStatsLink && (
                  <span class="fetch-hint">No REALTOR.ca stats link on this request — add one to enable fetch.</span>
                )
              }
            </div>
            <div class="dropzone" id="dropzone" tabindex="0">
              <strong>Drop photos here, click to browse, or paste a screenshot</strong>
              <span>JPEG / PNG / WebP — large images are downscaled in the browser before upload.</span>
            </div>
            <input type="file" id="file-input" multiple accept="image/jpeg,image/png,image/webp" hidden />
            <p class="hint" id="upload-note" hidden></p>
            {
              photos.length > 0 ? (
                <>
                  <div class="photo-grid" id="photo-grid">
                    {photos.map((photo) => (
                      <button type="button" class="photo-thumb" data-id={photo.id} title={photo.original_name}>
                        <img src={`${uploadsBase}/${photo.id}`} alt={photo.original_name} loading="lazy" />
                        <span class="order-badge" />
                      </button>
                    ))}
                  </div>
                  <p class="hint grid-hint">
                    Click a photo to add or remove it from the album — the badge number is the publish order.
                  </p>
                </>
              ) : (
                <div class="empty-state">
                  <strong>No post photos yet</strong>
                  <p>Upload the hand-picked listing photos — they join the post album automatically.</p>
                </div>
              )
            }
          </section>

          <div class="actions-row">
            <button class="button secondary" type="submit" name="action" value="save">Save Draft</button>
            {
              canReady && (
                <button class="button primary" type="submit" name="action" value="ready">
                  Mark Ready for Review
                </button>
              )
            }
            {
              isExtendAtNewOrder && (
                <p class="notice grey">
                  This is an Extend Existing Campaign request — skip straight to Record Ad Launch on the{" "}
                  <a href={`/requests/${request.id}#card-campaign`}>request page</a>.
                </p>
              )
            }
          </div>
        </form>

        {
          canPublish && shortLink && (
            <div class="panel editor-panel publish-panel">
              <h2>Push live</h2>
              <p class="hint">
                Publishes the saved final text + selected photos to {brokerage.name}'s Facebook Page. Save Draft first
                if you just changed anything.
              </p>
              <form method="post" action={publishApi} id="publish-form">
                <button class="button primary" type="submit">Push Live to Facebook</button>
              </form>
              <form method="post" action={postApi} class="manual-row">
                <input type="hidden" name="action" value="record_manual" />
                <label class="client-field wide">
                  <span>Posted it by hand in Meta? Paste the post URL</span>
                  <input type="url" name="manual_permalink" placeholder="https://www.facebook.com/..." required />
                </label>
                <button class="button secondary sm" type="submit">Record manual publish</button>
              </form>
            </div>
          )
        }
        {
          request.status === "post_created" && (
            <p class="notice grey">Waiting for review — approve the post from the request page to unlock publishing.</p>
          )
        }
      </div>

      <aside class="editor-right">
        <p class="eyebrow">Live preview</p>
        <div class="fb-card">
          <div class="fb-head">
            {
              brokerage.logo_url ? (
                <img class="fb-avatar" src={brokerage.logo_url} alt={brokerage.name} />
              ) : (
                <span class="fb-avatar fb-avatar-fallback">{brokerage.name.slice(0, 1)}</span>
              )
            }
            <div>
              <div class="fb-name">{brokerage.name}</div>
              <div class="fb-sub">Just now · 🌐</div>
            </div>
          </div>
          <div class="fb-text" id="pv-text"></div>
          <div class="fb-grid" id="pv-grid" hidden></div>
          <div class="fb-actions">
            <span>👍 Like</span>
            <span>💬 Comment</span>
            <span>↗ Share</span>
          </div>
        </div>
      </aside>
    </div>
  </main>
</AppLayout>

<script
  is:inline
  define:vars={{
    shortLink,
    phoneLine: brokerage.post_phone_line,
    signoff: brokerage.post_signoff,
    address: request.listing_address,
    pageName: brokerage.name,
    uploadApi,
    fetchPhotosApi,
    uploadsBase,
    initialSelection,
    requestId: request.id
  }}
>
  const form = document.getElementById("post-form");
  const flagSel = document.getElementById("f-flag");
  const prefixSel = document.getElementById("f-prefix");
  const priceInput = document.getElementById("f-price");
  const bedsInput = document.getElementById("f-beds");
  const bathsInput = document.getElementById("f-baths");
  const neighInput = document.getElementById("f-neigh");
  const bodyTa = document.getElementById("f-body");
  const finalTa = document.getElementById("f-final");
  const dirtyInput = document.getElementById("f-dirty");
  const photoIdsInput = document.getElementById("f-photo-ids");
  const pvText = document.getElementById("pv-text");
  const pvGrid = document.getElementById("pv-grid");
  const pickCount = document.getElementById("pick-count");
  const uploadNote = document.getElementById("upload-note");
  const dropzone = document.getElementById("dropzone");
  const fileInput = document.getElementById("file-input");
  const photoGrid = document.getElementById("photo-grid");
  const publishForm = document.getElementById("publish-form");
  const MAX_PHOTOS = 10;
  const stateKey = "post-editor-" + requestId;

  // --- Caption assembly: line-by-line mirror of lib/postFormat.ts ----------
  function assemble() {
    const head = [];
    const flag = flagSel.value.trim();
    head.push(flag ? "🚨 " + flag + "!🚨 " + address : address);
    if (shortLink) head.push(shortLink);

    const price = priceInput.value.trim().replace(/^\$/, "");
    if (price) head.push("💲 " + (prefixSel.value.trim() || "Offered at") + " $" + price);

    const beds = bedsInput.value.trim();
    const baths = bathsInput.value.trim();
    if (beds && baths) head.push("🛏️ " + beds + " Bedrooms | 🛁 " + baths + " Bathrooms");
    else if (beds) head.push("🛏️ " + beds + " Bedrooms");
    else if (baths) head.push("🛁 " + baths + " Bathrooms");

    const neighborhood = neighInput.value.trim();
    if (neighborhood) head.push("📍 " + neighborhood);

    const tail = [];
    if (shortLink) tail.push("🔗 " + shortLink);
    if (phoneLine.trim()) tail.push("📞" + phoneLine.trim());
    if (signoff.trim()) tail.push(signoff.trim());

    const body = bodyTa.value.trim();
    return [head.join("\n"), body, tail.join("\n")].filter(Boolean).join("\n\n");
  }

  function syncPreview() {
    pvText.textContent = finalTa.value;
  }

  function onFormInput(event) {
    const target = event.target;
    if (target === finalTa) {
      dirtyInput.value = "1"; // first manual edit stops auto-assembly
    } else if (target === fileInput) {
      return;
    } else {
      if (target === flagSel && flagSel.value === "PRICE REDUCED") {
        prefixSel.value = "Now Offered at"; // auto-suggest, still editable
      }
      if (dirtyInput.value !== "1") finalTa.value = assemble();
    }
    syncPreview();
  }
  form.addEventListener("input", onFormInput);
  form.addEventListener("change", onFormInput);

  document.getElementById("regen").addEventListener("click", () => {
    dirtyInput.value = "0";
    finalTa.value = assemble();
    syncPreview();
  });

  // --- Photo selection: click toggles, order = publish order ----------------
  let selection = initialSelection.slice(0, MAX_PHOTOS);

  function renderSelection() {
    if (photoGrid) {
      for (const thumb of photoGrid.querySelectorAll(".photo-thumb")) {
        const index = selection.indexOf(thumb.dataset.id);
        thumb.classList.toggle("selected", index !== -1);
        thumb.querySelector(".order-badge").textContent = index === -1 ? "" : String(index + 1);
      }
    }
    photoIdsInput.value = selection.join(",");
    if (pickCount) pickCount.textContent = selection.length + " of " + MAX_PHOTOS + " picked";

    pvGrid.textContent = "";
    for (const id of selection) {
      const img = document.createElement("img");
      img.src = uploadsBase + "/" + id;
      img.alt = "";
      pvGrid.appendChild(img);
    }
    pvGrid.classList.toggle("odd", selection.length % 2 === 1);
    pvGrid.hidden = selection.length === 0;
  }

  if (photoGrid) {
    photoGrid.addEventListener("click", (event) => {
      const thumb = event.target.closest(".photo-thumb");
      if (!thumb) return;
      const id = thumb.dataset.id;
      const index = selection.indexOf(id);
      if (index !== -1) {
        selection.splice(index, 1);
      } else if (selection.length < MAX_PHOTOS) {
        selection.push(id);
      } else {
        note("Maximum " + MAX_PHOTOS + " photos per post — unpick one first.", true);
        return;
      }
      renderSelection();
    });
  }

  // --- State preservation across upload reloads -----------------------------
  // Mirrors report.astro: persist the in-progress editor before the photo
  // upload reload, restore on next load, then clear the key.
  function saveState() {
    const state = {
      headline_flag: flagSel ? flagSel.value : "",
      price_prefix: prefixSel ? prefixSel.value : "",
      price: priceInput ? priceInput.value : "",
      beds: bedsInput ? bedsInput.value : "",
      baths: bathsInput ? bathsInput.value : "",
      neighborhood: neighInput ? neighInput.value : "",
      body: bodyTa ? bodyTa.value : "",
      final_text: finalTa ? finalTa.value : "",
      dirty: dirtyInput ? dirtyInput.value : "0",
      photo_ids: selection.slice()
    };
    try {
      sessionStorage.setItem(stateKey, JSON.stringify(state));
    } catch {
      /* storage full/blocked — state loss on reload is acceptable */
    }
  }

  function restoreState() {
    let raw = null;
    try {
      raw = sessionStorage.getItem(stateKey);
    } catch {
      return;
    }
    if (!raw) return;
    try {
      sessionStorage.removeItem(stateKey);
    } catch {
      /* ignore */
    }
    let state;
    try {
      state = JSON.parse(raw);
    } catch {
      return;
    }
    if (!state) return;
    if (flagSel && typeof state.headline_flag === "string") flagSel.value = state.headline_flag;
    if (prefixSel && typeof state.price_prefix === "string") prefixSel.value = state.price_prefix;
    if (priceInput && typeof state.price === "string") priceInput.value = state.price;
    if (bedsInput && typeof state.beds === "string") bedsInput.value = state.beds;
    if (bathsInput && typeof state.baths === "string") bathsInput.value = state.baths;
    if (neighInput && typeof state.neighborhood === "string") neighInput.value = state.neighborhood;
    if (bodyTa && typeof state.body === "string") bodyTa.value = state.body;
    if (finalTa && typeof state.final_text === "string") finalTa.value = state.final_text;
    if (dirtyInput && typeof state.dirty === "string") dirtyInput.value = state.dirty;
    if (Array.isArray(state.photo_ids)) {
      const valid = new Set(initialSelection.slice());
      if (photoGrid) {
        for (const thumb of photoGrid.querySelectorAll(".photo-thumb")) valid.add(thumb.dataset.id);
      }
      selection = state.photo_ids.filter((id) => valid.has(id)).slice(0, MAX_PHOTOS);
    }
  }

  // --- Uploads: browse / drag-drop / paste, canvas downscale first ----------
  function note(message, isError) {
    uploadNote.hidden = false;
    uploadNote.textContent = message;
    uploadNote.style.color = isError ? "#b91c1c" : "";
  }

  async function prepareFile(file) {
    if (!/^image\/(jpeg|png|webp)$/.test(file.type)) return file; // server validates
    const url = URL.createObjectURL(file);
    try {
      const img = await new Promise((resolve, reject) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = reject;
        image.src = url;
      });
      const longest = Math.max(img.naturalWidth, img.naturalHeight);
      if (!longest || longest <= 2000) return file; // already small enough
      const scale = 2000 / longest;
      const canvas = document.createElement("canvas");
      canvas.width = Math.round(img.naturalWidth * scale);
      canvas.height = Math.round(img.naturalHeight * scale);
      canvas.getContext("2d").drawImage(img, 0, 0, canvas.width, canvas.height);
      const blob = await new Promise((resolve) => canvas.toBlob(resolve, "image/jpeg", 0.85));
      if (!blob) return file;
      const name = (file.name || "photo").replace(/\.[a-z0-9]+$/i, "") + ".jpg";
      return new File([blob], name, { type: "image/jpeg" });
    } catch {
      return file;
    } finally {
      URL.revokeObjectURL(url);
    }
  }

  let uploading = false;
  async function uploadFiles(fileList) {
    const files = Array.from(fileList).filter((file) => file.size > 0);
    if (files.length === 0 || uploading) return;
    uploading = true;
    note("Preparing " + files.length + " photo(s)…");
    try {
      const body = new FormData();
      body.append("kind", "post_photo");
      for (const file of files) {
        const prepared = await prepareFile(file);
        body.append("file", prepared, prepared.name || "upload");
      }
      note("Uploading " + files.length + " photo(s)…");
      const response = await fetch(uploadApi, { method: "POST", body });
      let data = null;
      try {
        data = await response.json();
      } catch {}
      if (response.ok && data && data.ok) {
        // New uploads join the album automatically (up to the cap) — the
        // preview should show them without requiring a click-to-select.
        for (const asset of data.assets || []) {
          if (selection.length >= MAX_PHOTOS) break;
          if (asset && asset.id && !selection.includes(asset.id)) selection.push(asset.id);
        }
        saveState();
        location.reload();
      } else {
        note((data && data.error) || "Upload failed — try again.", true);
        uploading = false;
      }
    } catch {
      note("Upload failed — check your connection and try again.", true);
      uploading = false;
    }
  }

  dropzone.addEventListener("click", () => fileInput.click());
  dropzone.addEventListener("keydown", (event) => {
    if (event.key === "Enter" || event.key === " ") {
      event.preventDefault();
      fileInput.click();
    }
  });
  fileInput.addEventListener("change", () => {
    if (fileInput.files && fileInput.files.length) uploadFiles(fileInput.files);
  });
  dropzone.addEventListener("dragover", (event) => {
    event.preventDefault();
    dropzone.classList.add("dragover");
  });
  dropzone.addEventListener("dragleave", () => dropzone.classList.remove("dragover"));
  dropzone.addEventListener("drop", (event) => {
    event.preventDefault();
    dropzone.classList.remove("dragover");
    if (event.dataTransfer && event.dataTransfer.files.length) uploadFiles(event.dataTransfer.files);
  });
  document.addEventListener("paste", (event) => {
    const items = event.clipboardData ? event.clipboardData.items : [];
    const files = [];
    for (const item of items) {
      if (item.kind === "file" && /^image\//.test(item.type)) {
        const file = item.getAsFile();
        if (file) files.push(new File([file], "paste-" + Date.now() + ".png", { type: file.type }));
      }
    }
    if (files.length) {
      event.preventDefault();
      uploadFiles(files);
    }
  });

  // --- Fetch photos from REALTOR.ca -----------------------------------------
  // Pulls the first 10 listing photos server-side (headless Chrome walks the
  // stats share link → public listing → gallery). On success we reuse the same
  // saveState() + reload() pattern as uploads so the new thumbnails render.
  const fetchButton = document.getElementById("fetch-photos");
  if (fetchButton) {
    fetchButton.addEventListener("click", async () => {
      if (uploading || fetchButton.disabled) return;
      uploading = true;
      const label = fetchButton.textContent;
      fetchButton.disabled = true;
      fetchButton.textContent = "Fetching from REALTOR.ca… ~30s";
      note("Fetching photos from REALTOR.ca — this takes about 30 seconds…");
      try {
        const response = await fetch(fetchPhotosApi, { method: "POST" });
        let data = null;
        try {
          data = await response.json();
        } catch {}
        const savedCount = data && typeof data.saved === "number" ? data.saved : 0;
        const warnings = data && Array.isArray(data.warnings) ? data.warnings : [];
        if (response.ok && savedCount > 0) {
          // Reload re-renders the grid from disk; fetched photos land unselected
          // (unlike dropzone uploads). Preserve the in-progress editor first.
          saveState();
          location.reload();
          return;
        }
        const message =
          (data && data.error) ||
          (warnings.length ? warnings.join(" ") : "No photos were fetched from REALTOR.ca — upload them manually.");
        note(message, true);
      } catch {
        note("Couldn't reach the photo fetcher — check your connection and try again.", true);
      } finally {
        // Only reached when we didn't reload (failure / zero saved).
        uploading = false;
        fetchButton.disabled = false;
        fetchButton.textContent = label;
      }
    });
  }

  // --- Publish confirmation -------------------------------------------------
  if (publishForm) {
    publishForm.addEventListener("submit", (event) => {
      if (!confirm("Publish this post to " + pageName + "'s Facebook Page now?")) {
        event.preventDefault();
      }
    });
  }

  // --- Initial paint ---------------------------------------------------------
  function initialPaint() {
    restoreState(); // re-apply any state stashed before an upload reload
    if (!finalTa.value.trim() && dirtyInput.value !== "1") {
      finalTa.value = assemble();
    }
    renderSelection();
    syncPreview();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initialPaint);
  } else {
    initialPaint();
  }
</script>

<style>
  .editor-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 18px;
    align-items: start;
  }

  .editor-left {
    display: grid;
    gap: 14px;
    min-width: 0;
  }

  .editor-left form {
    display: grid;
    gap: 14px;
  }

  .editor-right {
