---
import AppLayout from "../../layouts/AppLayout.astro";
import SupersonicBrand from "../../components/SupersonicBrand.astro";
import { formatNumber } from "../../lib/format";
import { readSnapshot } from "../../lib/storage";
import type { ExecReportSnapshot } from "../../lib/types";

// The Executive Report renders ONLY from the frozen snapshot — no request or
// brokerage reads. Every image is an embedded data URI; the page looks the
// same forever regardless of later edits or deleted uploads.
//
// Structure mirrors the owner's real reports: 5 minimal, screenshot-forward
// Letter pages (a 6th only when extra analytics screenshots overflow). Plain
// bold dark headings ending in a colon; the screenshots do the work.

const snapshotId = Astro.params.snapshotId ?? "";
const printMode = Astro.url.searchParams.get("print") === "1";
let snapshot: ExecReportSnapshot | undefined;

try {
  snapshot = await readSnapshot(snapshotId);
} catch {
  Astro.response.status = 404;
}

// A client arriving via the public ?t= share link (oversize-PDF email
// fallback) has no login: hide the internal Back link and carry the token
// onto the PDF download so that route passes the middleware too.
const shareTokenParam = Astro.url.searchParams.get("t") ?? "";
const shareViewer = Boolean(snapshot && shareTokenParam && snapshot.share_token === shareTokenParam);
const pdfHref = `/api/pdf/${snapshotId}${shareViewer ? `?t=${shareTokenParam}` : ""}`;
const backHref = snapshot ? `/requests/${snapshot.request_id}` : "/";

const gallery = snapshot ? snapshot.images.gallery.filter(Boolean) : [];

// In-Depth Data Of Users — the nowforsale.co link's click analytics, frozen at
// snapshot time (optional; older snapshots / no stats pulled → sheet omitted).
// The clicks chart is server-rendered SVG: no JS, no chart lib, print-safe.
const linkStats = snapshot?.link_stats;
const hasLinkStats = Boolean(
  linkStats && (linkStats.series.length > 0 || linkStats.total_clicks > 0)
);

const CHART_W = 640;
const CHART_H = 150;
type ChartGeometry = {
  areaPath: string;
  linePath: string;
  yLabels: { value: number; y: number }[];
  xLabels: { label: string; x: number }[];
};

function shortDate(iso: string): string {
  const date = new Date(`${iso}T00:00:00Z`);
  if (Number.isNaN(date.getTime())) return iso;
  return new Intl.DateTimeFormat("en-CA", { month: "short", day: "numeric", timeZone: "UTC" }).format(date);
}

function buildChart(series: { date: string; clicks: number }[]): ChartGeometry | undefined {
  if (series.length < 2) return undefined;
  const max = Math.max(...series.map((point) => point.clicks), 1);
  // Headroom + a round-ish top gridline value.
  const top = Math.max(5, Math.ceil((max * 1.1) / 5) * 5);
  const stepX = CHART_W / (series.length - 1);
  const pointAt = (index: number, clicks: number) =>
    `${(index * stepX).toFixed(1)},${(CHART_H - (clicks / top) * CHART_H).toFixed(1)}`;
  const line = series.map((point, index) => pointAt(index, point.clicks)).join(" L");
  const linePath = `M${line}`;
  const areaPath = `M0,${CHART_H} L${line} L${CHART_W},${CHART_H} Z`;
  const yLabels = [0, 1, 2, 3, 4].map((step) => ({
    value: Math.round((top / 4) * step),
    y: CHART_H - (CHART_H / 4) * step
  }));
  const labelEvery = Math.max(1, Math.ceil(series.length / 6));
  const xLabels = series
    .map((point, index) => ({ label: shortDate(point.date), x: index * stepX, index }))
    .filter(({ index }) => index % labelEvery === 0 || index === series.length - 1)
    .map(({ label, x }) => ({ label, x }));
  return { areaPath, linePath, yLabels, xLabels };
}

const chart = hasLinkStats ? buildChart(linkStats!.series) : undefined;
const linkLists = hasLinkStats
  ? [
      { title: "Top cities", rows: linkStats!.cities },
      { title: "Top countries", rows: linkStats!.countries },
      { title: "Top browsers", rows: linkStats!.browsers },
      { title: "Top operating systems", rows: linkStats!.os },
      { title: "Top referrers", rows: linkStats!.referrers }
    ].filter((list) => list.rows.length > 0)
  : [];

// REALTOR.ca — all present panes stacked on one sheet (omit missing/waived).
const realtorImages = snapshot
  ? [
      { label: "7-day", image: snapshot.images.realtor_7 },
      { label: "30-day", image: snapshot.images.realtor_30 },
      { label: "90-day", image: snapshot.images.realtor_90 }
    ].filter((pane) => pane.image)
  : [];

// Sample Overview — guard `ad_sample` (older snapshots predate the field). If
// manual mobile/desktop override screenshots exist, show them side by side;
// otherwise render one compact native Facebook-style mockup from ad_sample.
const adSample = snapshot?.ad_sample ?? { text: "", images: [] };
const adSampleImages = adSample.images.filter(Boolean);
const previewMobile = snapshot?.images.ad_preview_mobile ?? "";
const previewDesktop = snapshot?.images.ad_preview_desktop ?? "";
const previewShots = [previewMobile, previewDesktop].filter(Boolean);
const hasPreviewShots = previewShots.length > 0;

const hexColor = (value: string | undefined, fallback: string) =>
  value && /^#[0-9a-fA-F]{6}$/.test(value) ? value : fallback;

// Brand colors print as the thin cover rule / small accents on white sheets. A
// light brand color (say #f2e3c6) passes the hex check but is unreadable on
// paper — darken until it clears the large-text contrast threshold (3:1).
function readableOnWhite(hex: string): string {
  let [r, g, b] = [1, 3, 5].map((i) => parseInt(hex.slice(i, i + 2), 16));
  const luminance = () => {
    const chan = (c: number) => {
      const s = c / 255;
      return s <= 0.03928 ? s / 12.92 : ((s + 0.055) / 1.055) ** 2.4;
    };
    return 0.2126 * chan(r) + 0.7152 * chan(g) + 0.0722 * chan(b);
  };
  while (1.05 / (luminance() + 0.05) < 3 && (r > 0 || g > 0 || b > 0)) {
    r = Math.floor(r * 0.9);
    g = Math.floor(g * 0.9);
    b = Math.floor(b * 0.9);
  }
  const to2 = (n: number) => n.toString(16).padStart(2, "0");
  return `#${to2(r)}${to2(g)}${to2(b)}`;
}

const reportBrandStyle = snapshot
  ? [
      `--client-primary: ${readableOnWhite(hexColor(snapshot.brokerage.brand_primary, "#222222"))}`,
      `--client-accent: ${readableOnWhite(hexColor(snapshot.brokerage.brand_accent, "#c9a86a"))}`
    ].join("; ")
  : undefined;
---

<AppLayout
  title={snapshot ? `${snapshot.listing.address} | Executive Report` : "Report Not Found"}
  className="report-body"
>
  {snapshot ? (
    <main class="report-frame" style={reportBrandStyle}>
      {!printMode && (
        <div class="report-toolbar">
          <div class="report-toolbar-left">
            {!shareViewer && <a class="back-link" href={backHref}>&larr; Back</a>}
            <span class="report-toolbar-label">
              <SupersonicBrand wordmark={false} size={18} />
              Executive Report preview
            </span>
          </div>
          <a class="button primary" href={pdfHref} data-pdf-button>Download PDF</a>
        </div>
      )}
      {!printMode && (
        <script>
          // PDF generation launches a headless browser and takes several seconds with no
          // native feedback — show a busy state and swallow impatient repeat clicks.
          const pdfButton = document.querySelector("[data-pdf-button]") as HTMLAnchorElement | null;
          let busy = false;
          pdfButton?.addEventListener("click", (event) => {
            if (busy) {
              event.preventDefault();
              return;
            }
            busy = true;
            pdfButton.classList.add("is-busy");
            pdfButton.textContent = "Preparing PDF...";
            setTimeout(() => {
              busy = false;
              pdfButton.classList.remove("is-busy");
              pdfButton.textContent = "Download PDF";
            }, 30_000);
          });
        </script>
      )}

      <article class="report-document" aria-label="Executive advertising report">
        <!-- S1 · COVER -->
        <section class="report-sheet report-cover-sheet exr-cover">
          <div class="report-sheet-topline">
            <div class="report-brand-lockup">
              {snapshot.brokerage.logo_url ? (
                <img src={snapshot.brokerage.logo_url} alt={snapshot.brokerage.name} />
              ) : (
                <span class="report-brand-name">{snapshot.brokerage.name}</span>
              )}
            </div>
          </div>

          <header class="exr-cover-header">
            <h1>Executive Report: {snapshot.listing.address}</h1>
            <p class="exr-cover-sub">Online Advertising Campaign</p>
          </header>

          <div class="exr-cover-media">
            {snapshot.images.hero && (
              <div class="exr-cover-hero">
                <img src={snapshot.images.hero} alt={`${snapshot.listing.address}`} />
              </div>
            )}
            {gallery.length > 0 && (
              <div class="exr-cover-grid">
                {gallery.map((image, index) => (
                  <img src={image} alt={`Listing photo ${index + 1}`} />
                ))}
              </div>
            )}
          </div>
        </section>

        <!-- S2 · CAMPAIGN STATS + SAMPLE OVERVIEW -->
        <section class="report-sheet exr-stats-sheet">
          <p class="exr-intro">
            Below you will find the latest Facebook &amp; Instagram (Meta Ad platform) Ads campaigns stats.
          </p>

          <p class="exr-stat-line">
            <span>Total Ad Impressions: <strong>{formatNumber(snapshot.insights.impressions)}</strong></span>
            <span>Reach: <strong>{formatNumber(snapshot.insights.reach)}</strong></span>
            <span>All Clicks &amp; Likes: <strong>{formatNumber(snapshot.insights.clicks_all)}</strong></span>
          </p>

          <h2 class="exr-heading">Facebook &amp; Instagram Sample Overview:</h2>

          {hasPreviewShots ? (
            <div class:list={["exr-preview-shots", { single: previewShots.length === 1 }]}>
              {previewShots.map((image) => (
                <div class="exr-shot">
                  <img src={image} alt="Ad preview" />
                </div>
              ))}
            </div>
          ) : (
            <div class="exr-sample-frame">
              <article class="exr-fb-card">
                <div class="exr-fb-head">
                  {snapshot.brokerage.logo_url ? (
                    <img class="exr-fb-avatar" src={snapshot.brokerage.logo_url} alt={snapshot.brokerage.name} />
                  ) : (
                    <span class="exr-fb-avatar exr-fb-avatar-fallback">{snapshot.brokerage.name.slice(0, 1)}</span>
                  )}
                  <div>
                    <div class="exr-fb-name">{snapshot.brokerage.name}</div>
                    <div class="exr-fb-sub">Sponsored · 🌐</div>
                  </div>
                </div>
                {adSample.text && <div class="exr-fb-text">{adSample.text}</div>}
                {adSampleImages.length > 0 && (
                  <div class:list={["exr-fb-grid", { odd: adSampleImages.length % 2 === 1 }]}>
                    {adSampleImages.map((image, index) => (
                      <img src={image} alt={`Ad photo ${index + 1}`} />
                    ))}
                  </div>
                )}
                <div class="exr-fb-actions">
                  <span>👍 Like</span>
                  <span>💬 Comment</span>
                  <span>↗ Share</span>
                </div>
              </article>
            </div>
          )}
        </section>

        <!-- S3 · IN-DEPTH DATA OF USERS (short.io link analytics) -->
        {hasLinkStats && (
          <section class="report-sheet exr-depth-sheet">
            <h2 class="exr-heading">In-Depth Data Of Users:</h2>
            <p class="exr-caption">Ad campaign geo-targeting, user insights and visitor clicks on the listing.</p>

            {chart && (
              <div class="exr-chart-card">
                <div class="exr-chart-title">Clicks</div>
                <div class="exr-chart-body">
                  <div class="exr-chart-y">
                    {chart.yLabels
                      .slice()
                      .reverse()
                      .map((label) => (
                        <span>{formatNumber(label.value)}</span>
                      ))}
                  </div>
                  <div class="exr-chart-plot">
                    <svg
                      viewBox={`0 0 ${CHART_W} ${CHART_H}`}
                      preserveAspectRatio="none"
                      role="img"
                      aria-label="Clicks per day"
                    >
                      {chart.yLabels.map((label) => (
                        <line x1="0" y1={label.y} x2={CHART_W} y2={label.y} class="exr-gridline" />
                      ))}
                      <path d={chart.areaPath} class="exr-area" />
                      <path d={chart.linePath} class="exr-line" />
                    </svg>
                    <div class="exr-chart-x">
                      {chart.xLabels.map((label) => (
                        <span style={`left: ${(label.x / CHART_W) * 100}%`}>{label.label}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            )}

            <div class="exr-stat-tiles">
              <div class="exr-stat-tile">
                <span>Total clicks</span>
                <strong>{formatNumber(linkStats!.total_clicks)}</strong>
                <small>campaign period</small>
              </div>
              <div class="exr-stat-tile">
                <span>Human clicks</span>
                <strong>{formatNumber(linkStats!.human_clicks)}</strong>
                <small>campaign period</small>
              </div>
            </div>

            <div class="exr-list-grid">
              {linkLists.map((list) => {
                const max = Math.max(...list.rows.map((row) => row.clicks), 1);
                return (
                  <div class="exr-list-card">
                    <div class="exr-list-title">{list.title}</div>
                    {list.rows.map((row) => (
                      <div class="exr-list-row">
                        <span class="exr-list-name">{row.name}</span>
                        <span class="exr-list-count">{formatNumber(row.clicks)}</span>
                        <span class="exr-list-bar">
                          <span style={`width: ${Math.max(2, Math.round((row.clicks / max) * 100))}%`} />
                        </span>
                      </div>
                    ))}
                  </div>
                );
              })}
            </div>
          </section>
        )}

        <!-- S4 · REALTOR.ca MLS STATS -->
        {realtorImages.length > 0 && (
          <section class="report-sheet exr-realtor-sheet">
            <h2 class="exr-heading">7, 30, 90 Day Realtor.ca MLS Stats:</h2>
            <p class="exr-caption">Overview of users visiting MLS Realtor.ca listing for 7, 30, 90 days stats.</p>

            <div class="exr-realtor-stack">
              {realtorImages.map((pane) => (
                <div class="exr-shot exr-shot-realtor">
                  <img src={pane.image} alt={`REALTOR.ca ${pane.label} statistics`} />
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- S5 · DISCLAIMER -->
        <section class="report-sheet exr-disclaimer-sheet">
          <div class="exr-disclaimer-body">
            <p>
              This report is intended solely for the designated recipient and is provided for informational
              purposes only. All data is believed to be accurate at the time of publication but is subject to
              change. This document may contain personal information and should be handled in accordance with
              Provincial and Federal personal privacy laws.
            </p>
            <p>
              This report includes real estate advertising or listing content and complies with applicable
              regulations under the Real Estate Services Act.
            </p>
          </div>

          <div class="exr-prepared">
            <p>Prepared by {snapshot.brokerage.name}</p>
            {snapshot.brokerage.address_line && <p>Brokerage Address: {snapshot.brokerage.address_line}</p>}
            {snapshot.brokerage.contact_line && <p>Contact: {snapshot.brokerage.contact_line}</p>}
          </div>

          <footer class="report-footer">
            <span>{snapshot.brokerage.website}</span>
            <span>{snapshot.listing.address}</span>
          </footer>
        </section>
      </article>
    </main>
  ) : (
    <main class="form-shell">
      <section class="panel">
        <p class="eyebrow">Missing snapshot</p>
        <h1>Report not found</h1>
        <p>No report snapshot exists for <code>{snapshotId}</code>.</p>
        <a class="button primary" href="/">Back to the board</a>
      </section>
    </main>
  )}
</AppLayout>

<style>
  /* Executive-Report-specific pieces; the shared report sheet/print model lives
     in global.css and is untouched. The design is deliberately minimal: plain
     bold dark headings ending in a colon, muted body copy, and the screenshots
     doing the work — mirroring the owner's real reports. */

  /* Shared heading + caption -------------------------------------------------*/
  .exr-heading {
    margin: 0;
    color: var(--ink, #1b1b1b);
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .exr-caption {
    margin: 0;
    color: var(--muted, #837c6f);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
  }

  /* Screenshot frame — contained, no chrome (a faint hairline for definition). */
  .exr-shot {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .exr-shot img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  /* S1 · Cover ---------------------------------------------------------------*/
  .exr-cover {
    gap: 22px;
  }

  .exr-cover-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .exr-cover-header h1 {
    margin: 0;
    color: var(--ink, #1b1b1b);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.15;
  }

  .exr-cover-sub {
    margin: 0;
    color: var(--muted, #837c6f);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .exr-cover-media {
    display: flex;
    min-height: 0;
    flex: 1;
    flex-direction: column;
    gap: 12px;
  }

  .exr-cover-hero {
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    border-radius: 10px;
    background: var(--surface, #f6f5f1);
  }

  .exr-cover-hero img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .exr-cover-grid {
    display: grid;
    flex: 0 0 auto;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 1.55in;
    gap: 10px;
  }

  .exr-cover-grid img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    background: var(--surface, #f6f5f1);
  }

  /* S2 · Stats + Sample ------------------------------------------------------*/
  .exr-intro {
    margin: 0;
    color: var(--ink, #1b1b1b);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.55;
  }

  .exr-stat-line {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 26px;
    margin: 0;
    color: var(--ink, #1b1b1b);
    font-size: 1.15rem;
    font-weight: 500;
  }

  .exr-stat-line strong {
    font-size: 1.5rem;
    font-weight: 800;
  }

  /* Manual override screenshots, side by side (or single, centered). */
  .exr-preview-shots {
    display: grid;
    min-height: 0;
    flex: 1;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    align-items: start;
    justify-items: center;
  }

  .exr-preview-shots.single {
    grid-template-columns: minmax(0, 1fr);
  }

  .exr-preview-shots .exr-shot {
    width: 100%;
    height: 100%;
  }

  /* Native Facebook-style ad-sample mockup — one compact card, sized to fit the
     lower half of the sheet. */
  .exr-sample-frame {
    display: flex;
    min-height: 0;
    flex: 1;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
    padding-top: 4px;
  }

  .exr-fb-card {
    width: 4in;
    max-width: 100%;
    overflow: hidden;
    border: 1px solid #dadde1;
    border-radius: 10px;
    background: #ffffff;
  }

  .exr-fb-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }

  .exr-fb-avatar {
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    border-radius: 999px;
    background: #101725;
    object-fit: contain;
    padding: 3px;
  }

  .exr-fb-avatar-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-weight: 700;
  }

  .exr-fb-name {
    color: #050505;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .exr-fb-sub {
    color: #65676b;
    font-size: 0.76rem;
  }

  .exr-fb-text {
    padding: 0 14px 12px;
    color: #050505;
    font-size: 0.9rem;
    line-height: 1.45;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    display: -webkit-box;
    -webkit-line-clamp: 8;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .exr-fb-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2px;
  }

  .exr-fb-grid img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    background: #f0f2f5;
  }

  .exr-fb-grid.odd img:first-child {
    grid-column: 1 / -1;
    aspect-ratio: 16 / 10;
  }

  .exr-fb-actions {
    display: flex;
    border-top: 1px solid #e4e6eb;
  }

  .exr-fb-actions span {
    flex: 1;
    padding: 9px 0;
    color: #65676b;
    font-size: 0.82rem;
    font-weight: 600;
    text-align: center;
  }

  .exr-realtor-sheet,
  .exr-depth-sheet,
  .exr-stats-sheet {
    gap: 14px;
  }

  /* S3 · In-Depth (short.io link analytics) ----------------------------------*/
  .exr-chart-card {
    border: 1px solid #e7e5e0;
    border-radius: 10px;
    padding: 12px 16px 24px;
  }

  .exr-chart-title {
    margin-bottom: 10px;
    color: #1b1b1b;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .exr-chart-body {
    display: flex;
    gap: 8px;
  }

  .exr-chart-y {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-bottom: 2px;
    color: #837c6f;
    font-size: 0.62rem;
    text-align: right;
  }

  .exr-chart-plot {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .exr-chart-plot svg {
    display: block;
    width: 100%;
    height: 1.25in;
  }

  .exr-gridline {
    stroke: #efede8;
    stroke-width: 1;
  }

  .exr-area {
    fill: color-mix(in srgb, var(--client-accent, #2fbfa7) 18%, #ffffff);
  }

  .exr-line {
    fill: none;
    stroke: var(--client-accent, #2fbfa7);
    stroke-width: 2;
  }

  .exr-chart-x {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -18px;
    height: 14px;
  }

  .exr-chart-x span {
    position: absolute;
    transform: translateX(-50%);
    color: #837c6f;
    font-size: 0.62rem;
    white-space: nowrap;
  }

  .exr-stat-tiles {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .exr-stat-tile {
    display: grid;
