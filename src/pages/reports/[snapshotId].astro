---
import AppLayout from "../../layouts/AppLayout.astro";
import SupersonicBrand from "../../components/SupersonicBrand.astro";
import { formatDateRange, formatNumber } from "../../lib/format";
import { readSnapshot } from "../../lib/storage";
import type { ExecReportSnapshot } from "../../lib/types";

// The Executive Report renders ONLY from the frozen snapshot — no request or
// brokerage reads. Every image is an embedded data URI; the page looks the
// same forever regardless of later edits or deleted uploads.

const snapshotId = Astro.params.snapshotId ?? "";
const printMode = Astro.url.searchParams.get("print") === "1";
let snapshot: ExecReportSnapshot | undefined;

try {
  snapshot = await readSnapshot(snapshotId);
} catch {
  Astro.response.status = 404;
}

// A client arriving via the public ?t= share link (oversize-PDF email
// fallback) has no login: hide the internal Back link and carry the token
// onto the PDF download so that route passes the middleware too.
const shareTokenParam = Astro.url.searchParams.get("t") ?? "";
const shareViewer = Boolean(snapshot && shareTokenParam && snapshot.share_token === shareTokenParam);
const pdfHref = `/api/pdf/${snapshotId}${shareViewer ? `?t=${shareTokenParam}` : ""}`;
const backHref = snapshot ? `/requests/${snapshot.request_id}` : "/";

const dateRange = snapshot
  ? formatDateRange(snapshot.campaign.ad_launch_date, snapshot.campaign.report_due_date)
  : "";
const citiesLine = snapshot ? snapshot.campaign.target_cities.join(", ") : "";

const regionRows = snapshot ? snapshot.insights.region.slice(0, 8) : [];
const ageGenderRows = snapshot ? snapshot.insights.age_gender.slice(0, 8) : [];
const hasBreakdownRows = regionRows.length > 0 || ageGenderRows.length > 0;
const insightsScreens = snapshot ? snapshot.images.insights_screens.filter(Boolean) : [];
// Tables present -> every screenshot goes to a continuation sheet. No tables ->
// the first screenshot takes the main In-Depth sheet, the rest continue.
const primaryScreen = !hasBreakdownRows && insightsScreens.length > 0 ? insightsScreens[0] : "";
const continuationScreens = hasBreakdownRows ? insightsScreens : insightsScreens.slice(1);
const hasInDepthSheet = hasBreakdownRows || insightsScreens.length > 0;

const realtorSheets = snapshot
  ? ([
      { label: "7 day view", image: snapshot.images.realtor_7 },
      { label: "30 day view", image: snapshot.images.realtor_30 },
      { label: "90 day view", image: snapshot.images.realtor_90 }
    ].filter((sheet) => sheet.image))
  : [];

const campaignTypeLabel = snapshot
  ? snapshot.campaign.campaign_type === "extend"
    ? "Campaign extension"
    : "New campaign"
  : "";

const hexColor = (value: string | undefined, fallback: string) =>
  value && /^#[0-9a-fA-F]{6}$/.test(value) ? value : fallback;

// Brand colors print as text/icons on white sheets. A light brand color (say #f2e3c6)
// passes the hex check but is unreadable on paper — darken until it clears the
// large-text contrast threshold (3:1 against white).
function readableOnWhite(hex: string): string {
  let [r, g, b] = [1, 3, 5].map((i) => parseInt(hex.slice(i, i + 2), 16));
  const luminance = () => {
    const chan = (c: number) => {
      const s = c / 255;
      return s <= 0.03928 ? s / 12.92 : ((s + 0.055) / 1.055) ** 2.4;
    };
    return 0.2126 * chan(r) + 0.7152 * chan(g) + 0.0722 * chan(b);
  };
  while (1.05 / (luminance() + 0.05) < 3 && (r > 0 || g > 0 || b > 0)) {
    r = Math.floor(r * 0.9);
    g = Math.floor(g * 0.9);
    b = Math.floor(b * 0.9);
  }
  const to2 = (n: number) => n.toString(16).padStart(2, "0");
  return `#${to2(r)}${to2(g)}${to2(b)}`;
}

const reportBrandStyle = snapshot
  ? [
      `--client-primary: ${readableOnWhite(hexColor(snapshot.brokerage.brand_primary, "#222222"))}`,
      `--client-accent: ${readableOnWhite(hexColor(snapshot.brokerage.brand_accent, "#c9a86a"))}`
    ].join("; ")
  : undefined;

// --- Small hand-authored inline icon set. Generic geometric line icons only,
// stroke-based, inherit color via currentColor. ---
type IconName = "eye" | "people" | "calendar" | "trending-up" | "camera" | "globe" | "home" | "building";

const iconPaths: Record<IconName, string> = {
  eye: '<path d="M1.5 9S4.5 3.5 9 3.5 16.5 9 16.5 9 13.5 14.5 9 14.5 1.5 9 1.5 9Z"/><circle cx="9" cy="9" r="2.5"/>',
  people:
    '<circle cx="6.5" cy="6" r="2.5"/><path d="M2 15c0-2.49 2.01-4.5 4.5-4.5S11 12.51 11 15"/><circle cx="13" cy="7" r="2"/><path d="M12 10.6c1.97.32 3.5 1.94 3.5 4.4"/>',
  calendar:
    '<rect x="2.25" y="3.5" width="13.5" height="12" rx="1.5"/><path d="M2.25 7.25h13.5"/><path d="M6 1.75v3"/><path d="M12 1.75v3"/>',
  "trending-up": '<path d="M2 13.5 7.25 8l3 3 5.75-6.5"/><path d="M12.5 4.25H16v3.5"/>',
  camera:
    '<rect x="1.75" y="5" width="14.5" height="10" rx="1.75"/><path d="M6 5l1.25-2h3.5L12 5"/><circle cx="9" cy="10" r="3"/>',
  globe:
    '<circle cx="9" cy="9" r="7.25"/><path d="M1.75 9h14.5"/><path d="M9 1.75c2.1 2.05 3.25 4.6 3.25 7.25s-1.15 5.2-3.25 7.25C6.9 14.2 5.75 11.65 5.75 9S6.9 3.8 9 1.75Z"/>',
  home: '<path d="M2.5 8.5 9 2.75l6.5 5.75"/><path d="M4.25 7v8.25h9.5V7"/><path d="M7.25 15.25v-4.5h3.5v4.5"/>',
  building:
    '<rect x="3.5" y="2" width="11" height="14.25" rx="1"/><path d="M6.25 5.25h1.5M10.25 5.25h1.5M6.25 8.5h1.5M10.25 8.5h1.5M6.25 11.75h1.5M10.25 11.75h1.5"/><path d="M7.25 16.25V13.5h3.5v2.75"/>'
};

type IconProps = { name: IconName; size?: number };
const Icon = ({ name, size = 18 }: IconProps) =>
  `<svg width="${size}" height="${size}" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${iconPaths[name]}</svg>`;
---

<AppLayout
  title={snapshot ? `${snapshot.listing.address} | Executive Report` : "Report Not Found"}
  className="report-body"
>
  {snapshot ? (
    <main class="report-frame" style={reportBrandStyle}>
      {!printMode && (
        <div class="report-toolbar">
          <div class="report-toolbar-left">
            {!shareViewer && <a class="back-link" href={backHref}>&larr; Back</a>}
            <span class="report-toolbar-label">
              <SupersonicBrand wordmark={false} size={18} />
              Executive Report preview
            </span>
          </div>
          <a class="button primary" href={pdfHref} data-pdf-button>Download PDF</a>
        </div>
      )}
      {!printMode && (
        <script>
          // PDF generation launches a headless browser and takes several seconds with no
          // native feedback — show a busy state and swallow impatient repeat clicks.
          const pdfButton = document.querySelector("[data-pdf-button]") as HTMLAnchorElement | null;
          let busy = false;
          pdfButton?.addEventListener("click", (event) => {
            if (busy) {
              event.preventDefault();
              return;
            }
            busy = true;
            pdfButton.classList.add("is-busy");
            pdfButton.textContent = "Preparing PDF...";
            setTimeout(() => {
              busy = false;
              pdfButton.classList.remove("is-busy");
              pdfButton.textContent = "Download PDF";
            }, 30_000);
          });
        </script>
      )}

      <article class="report-document" aria-label="Executive advertising report">
        <!-- p1 · COVER -->
        <section class="report-sheet report-cover-sheet">
          <div class="report-sheet-topline">
            <div class="report-brand-lockup">
              {snapshot.brokerage.logo_url ? (
                <img src={snapshot.brokerage.logo_url} alt={snapshot.brokerage.name} />
              ) : (
                <span class="report-brand-name">{snapshot.brokerage.name}</span>
              )}
            </div>
            <p class="report-eyebrow-label">Executive Report</p>
          </div>

          <header class="report-cover-header">
            <div class="report-cover-title">
              <p>Online Advertising Campaign</p>
              <h1>Executive Report: {snapshot.listing.address}</h1>
            </div>
            <div class="report-period-pill">
              <Fragment set:html={Icon({ name: "calendar", size: 16 })} />
              <div class="report-period-text">
                <span class="report-period-label">Campaign period</span>
                <span class="report-period-value">{dateRange}</span>
              </div>
            </div>
          </header>

          {snapshot.images.hero ? (
            <div class="exr-hero-panel">
              <img src={snapshot.images.hero} alt={`${snapshot.listing.address} hero photo`} />
            </div>
          ) : (
            <div class="exr-hero-panel exr-media-empty" aria-hidden="true">
              <Fragment set:html={Icon({ name: "camera", size: 30 })} />
            </div>
          )}
        </section>

        <!-- p2 · CAMPAIGN STATS -->
        <section class="report-sheet">
          <header class="report-section-heading">
            <span>01</span>
            <div>
              <p>Meta ads campaign</p>
              <h2>Campaign results</h2>
            </div>
          </header>

          <section class="report-widget-row exr-widget-row-3" aria-label="Campaign metrics">
            <article class="report-widget">
              <span class="report-widget-icon"><Fragment set:html={Icon({ name: "eye" })} /></span>
              <div class="report-widget-body">
                <span>Total Ad Impressions</span>
                <strong>{formatNumber(snapshot.insights.impressions)}</strong>
              </div>
            </article>
            <article class="report-widget">
              <span class="report-widget-icon"><Fragment set:html={Icon({ name: "people" })} /></span>
              <div class="report-widget-body">
                <span>Reach</span>
                <strong>{formatNumber(snapshot.insights.reach)}</strong>
              </div>
            </article>
            <article class="report-widget">
              <span class="report-widget-icon"><Fragment set:html={Icon({ name: "trending-up" })} /></span>
              <div class="report-widget-body">
                <span>All Clicks &amp; Likes</span>
                <strong>{formatNumber(snapshot.insights.clicks_all)}</strong>
              </div>
            </article>
          </section>

          <div class="report-summary-card">
            <span class="report-outline-label">Summary</span>
            <p>
              Your listing was advertised across Facebook and Instagram to home buyers in {citiesLine}.
            </p>
          </div>

          <footer class="exr-chip-strip">
            <span class="exr-chip">$ {snapshot.campaign.budget} campaign</span>
            <span class="exr-chip">{campaignTypeLabel}</span>
            {snapshot.campaign.fb_campaign_id && (
              <span class="exr-chip exr-chip-mono">Campaign ID {snapshot.campaign.fb_campaign_id}</span>
            )}
          </footer>
        </section>

        <!-- p3 · SAMPLE OVERVIEW — MOBILE -->
        {snapshot.images.ad_preview_mobile && (
          <section class="report-sheet">
            <header class="report-section-heading">
              <span>02</span>
              <div>
                <p>Facebook &amp; Instagram Sample Overview</p>
                <h2>Mobile feed</h2>
              </div>
            </header>
            <div class="exr-contain-panel">
              <img src={snapshot.images.ad_preview_mobile} alt="Mobile feed ad preview" />
            </div>
            <p class="exr-caption">How your ad appeared in the Facebook &amp; Instagram mobile feed.</p>
          </section>
        )}

        <!-- p4 · SAMPLE OVERVIEW — DESKTOP -->
        {snapshot.images.ad_preview_desktop && (
          <section class="report-sheet">
            <header class="report-section-heading">
              <span>02</span>
              <div>
                <p>Facebook &amp; Instagram Sample Overview</p>
                <h2>Desktop feed</h2>
              </div>
            </header>
            <div class="exr-contain-panel">
              <img src={snapshot.images.ad_preview_desktop} alt="Desktop feed ad preview" />
            </div>
            <p class="exr-caption">How your ad appeared in the Facebook &amp; Instagram desktop feed.</p>
          </section>
        )}

        <!-- p5 · IN-DEPTH DATA OF USERS -->
        {hasInDepthSheet && (
          <section class="report-sheet">
            <header class="report-section-heading">
              <span>03</span>
              <div>
                <p>In-Depth Data Of Users</p>
                <h2>Ad campaign geo-targeting, user insights and visitor clicks on the listing</h2>
              </div>
            </header>

            {hasBreakdownRows ? (
              <Fragment>
                {regionRows.length > 0 && (
                  <section class="report-table-card" aria-label="Regional breakdown">
                    <div class="exr-data-row exr-data-head">
                      <span>Region</span>
                      <span>Impressions</span>
                      <span>Reach</span>
                      <span>Clicks</span>
                    </div>
                    {regionRows.map((row) => (
                      <div class="exr-data-row">
                        <span>{row.key}</span>
                        <strong>{formatNumber(row.impressions)}</strong>
                        <strong>{formatNumber(row.reach)}</strong>
                        <strong>{formatNumber(row.clicks)}</strong>
                      </div>
                    ))}
                  </section>
                )}
                {ageGenderRows.length > 0 && (
                  <section class="report-table-card" aria-label="Age and gender breakdown">
                    <div class="exr-data-row exr-data-head">
                      <span>Age &amp; Gender</span>
                      <span>Impressions</span>
                      <span>Reach</span>
                      <span>Clicks</span>
                    </div>
                    {ageGenderRows.map((row) => (
                      <div class="exr-data-row">
                        <span>{row.key}</span>
                        <strong>{formatNumber(row.impressions)}</strong>
                        <strong>{formatNumber(row.reach)}</strong>
                        <strong>{formatNumber(row.clicks)}</strong>
                      </div>
                    ))}
                  </section>
                )}
              </Fragment>
            ) : (
              <div class="exr-contain-panel exr-contain-tall">
                <img src={primaryScreen} alt="Ads Manager audience insights screenshot" />
              </div>
            )}
          </section>
        )}

        {continuationScreens.map((screen) => (
          <section class="report-sheet">
            <header class="report-section-heading">
              <span>03</span>
              <div>
                <p>In-Depth Data — continued</p>
                <h2>Ads Manager insights</h2>
              </div>
            </header>
            <div class="exr-contain-panel exr-contain-tall">
              <img src={screen} alt="Ads Manager audience insights screenshot" />
            </div>
          </section>
        ))}

        <!-- p6–8 · REALTOR.CA -->
        {realtorSheets.map((sheet) => (
          <section class="report-sheet">
            <header class="report-section-heading">
              <span>04</span>
              <div>
                <p>REALTOR.ca performance</p>
                <h2>{sheet.label}</h2>
              </div>
            </header>
            <div class="exr-contain-panel exr-contain-realtor">
              <img src={sheet.image} alt={`REALTOR.ca ${sheet.label} statistics screenshot`} />
            </div>
          </section>
        ))}

        <!-- p9 · GALLERY -->
        <section class="report-sheet">
          <header class="report-section-heading">
            <span>05</span>
            <div>
              <p>The listing</p>
              <h2>Photo highlights</h2>
            </div>
          </header>

          {snapshot.images.hero ? (
            <div class="exr-gallery-hero">
              <img src={snapshot.images.hero} alt={`${snapshot.listing.address} hero photo`} />
            </div>
          ) : (
            <div class="exr-gallery-hero exr-media-empty" aria-hidden="true">
              <Fragment set:html={Icon({ name: "camera", size: 30 })} />
            </div>
          )}

          <div class="exr-gallery-grid">
            {snapshot.images.gallery.map((image, index) =>
              image ? (
                <img src={image} alt={`Listing photo ${index + 1}`} />
              ) : (
                <div class="exr-media-empty" aria-hidden="true">
                  <Fragment set:html={Icon({ name: "camera", size: 22 })} />
                </div>
              )
            )}
          </div>
        </section>

        <!-- p10 · DISCLAIMER -->
        <section class="report-sheet">
          <header class="report-section-heading">
            <span>06</span>
            <div>
              <p>Compliance</p>
              <h2>Disclaimer</h2>
            </div>
          </header>

          <section class="report-disclaimer-card" aria-label="Report disclaimer">
            <p>
              This report is intended solely for the designated recipient and is provided for informational
              purposes only. All data is believed to be accurate at the time of publication but is subject to
              change. This document may contain personal information and should be handled in accordance with
              Provincial and Federal personal privacy laws.
            </p>
            <p>
              This report includes real estate advertising or listing content and complies with applicable
              regulations under the Real Estate Services Act.
            </p>
            <dl>
              <div>
                <dt>Prepared by</dt>
                <dd>{snapshot.brokerage.name}</dd>
              </div>
              {snapshot.brokerage.address_line && (
                <div>
                  <dt>Brokerage address</dt>
                  <dd>{snapshot.brokerage.address_line}</dd>
                </div>
              )}
              {snapshot.brokerage.contact_line && (
                <div>
                  <dt>Contact</dt>
                  <dd>{snapshot.brokerage.contact_line}</dd>
                </div>
              )}
            </dl>
          </section>

          <footer class="report-footer">
            <span>{snapshot.brokerage.website}</span>
            <span>{snapshot.listing.address}</span>
          </footer>
        </section>
      </article>
    </main>
  ) : (
    <main class="form-shell">
      <section class="panel">
        <p class="eyebrow">Missing snapshot</p>
        <h1>Report not found</h1>
        <p>No report snapshot exists for <code>{snapshotId}</code>.</p>
        <a class="button primary" href="/">Back to the board</a>
      </section>
    </main>
  )}
</AppLayout>

<style>
  /* Executive-Report-specific pieces; the shared report sheet/print model lives
     in global.css and is untouched. */

  .exr-hero-panel {
    height: 5in;
    overflow: hidden;
    border-radius: 12px;
    background: var(--surface, #f6f5f1);
  }

  .exr-hero-panel img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .exr-media-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c8c4bc;
    background: var(--surface, #f6f5f1);
    border-radius: 12px;
  }

  .exr-widget-row-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .exr-chip-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    border-top: 1px solid var(--hairline, #e4e1da);
    padding-top: 18px;
  }

  .exr-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--client-accent) 16%, #ffffff);
    color: var(--client-primary);
    padding: 7px 14px;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .exr-chip-mono {
    background: var(--surface, #f6f5f1);
    color: var(--muted, #837c6f);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 600;
  }

  /* Contained screenshot panels (ad previews, Ads Manager, REALTOR.ca). */
  .exr-contain-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 12px;
    background: var(--surface, #f6f5f1);
    padding: 16px;
  }

  .exr-contain-panel img {
    display: block;
    max-width: 100%;
    max-height: 8in;
    object-fit: contain;
    border-radius: 8px;
  }

  .exr-contain-tall img {
    max-height: 8.4in;
  }

  .exr-contain-realtor img {
    max-height: 8.2in;
  }

  .exr-caption {
    margin: 0;
    color: var(--muted, #837c6f);
    font-size: 0.86rem;
    font-weight: 600;
    text-align: center;
  }

  /* Four-column breakdown tables (no icon column, three numeric columns). */
  .exr-data-row {
    display: grid;
    grid-template-columns: 1.5fr 0.8fr 0.8fr 0.8fr;
    gap: 14px;
    align-items: center;
    padding: 12px 18px;
  }

  .exr-data-row + .exr-data-row {
    border-top: 1px solid var(--hairline, #e4e1da);
  }

  .exr-data-row span {
    color: var(--ink, #1b1b1b);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .exr-data-row strong {
    justify-self: end;
    color: var(--ink, #1b1b1b);
    font-size: 0.92rem;
    font-weight: 740;
  }

  .exr-data-head {
    border-bottom: 1px solid var(--hairline, #e4e1da);
  }

  .exr-data-head span {
    color: var(--muted, #837c6f);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .exr-data-head span:not(:first-child) {
    justify-self: end;
  }

  /* Gallery: hero large + 6 in a fixed 3x2 grid. */
  .exr-gallery-hero {
    height: 4in;
    overflow: hidden;
    border-radius: 12px;
    background: var(--surface, #f6f5f1);
  }

  .exr-gallery-hero img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .exr-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 1.85in;
    gap: 12px;
  }

  .exr-gallery-grid img,
  .exr-gallery-grid .exr-media-empty {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 9px;
    background: var(--surface, #f6f5f1);
  }

  @media (max-width: 760px) {
    .exr-hero-panel {
      height: 3in;
    }

    .exr-widget-row-3 {
      grid-template-columns: 1fr;
    }

    .exr-gallery-hero {
      height: 2.6in;
    }

    .exr-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: 1.5in;
    }

    .exr-data-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .exr-data-row strong {
      justify-self: start;
    }
  }

  @media print {
    .exr-hero-panel {
      height: 4.9in;
    }

    .exr-contain-panel img {
      max-height: 7.8in;
    }

    .exr-contain-tall img {
      max-height: 8.2in;
    }

    .exr-contain-realtor img {
      max-height: 8in;
    }

    .exr-gallery-hero {
      height: 3.9in;
    }

    .exr-gallery-grid {
      grid-auto-rows: 1.8in;
    }
  }
</style>
