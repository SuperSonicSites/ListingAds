# --- Auth ---------------------------------------------------------------
ADMIN_PASSWORD=                # team login password (admin cookie gate)

# --- Meta (Graph + Marketing API) ----------------------------------------
# System-user token from Business Manager. Required scopes:
#   pages_manage_posts, pages_read_engagement, pages_show_list  (post publishing)
#   ads_read, business_management                               (insights + ad creative)
META_SYSTEM_USER_TOKEN=

# --- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=                # re_... — sending domain must be DKIM/SPF-verified in Resend
EMAIL_FROM="Supersonic Sites <hello@supersonicsites.com>"
EMAIL_REPLY_TO=                # team inbox — reply-to on every outbound email
TEAM_EMAIL=                    # internal notifications: report-ready + due reminders
TEAM_NAME=team                 # greeting name in the report-ready email ("Hi {TEAM_NAME},")
REVIEW_EMAIL=brent@supersonicsites.com

# --- short.io --------------------------------------------------------------
SHORTIO_API_KEY=               # sk_... secret key (sent raw in the Authorization header)
SHORTIO_DOMAIN=nowforsale.co

# --- App -------------------------------------------------------------------
APP_BASE_URL=                  # e.g. https://ads.supersonicsites.com — CRM links in emails
CHROME_PATH=                   # optional: Chrome/Edge/Chromium binary for PDF + REALTOR.ca capture
DEMO_MODE=                     # 1 = labeled mock data when a credential is missing
PORT=4322                      # local dev beside SupersonicAnalytics (4321)
